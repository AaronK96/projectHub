{% extends 'base.html.twig' %}

{% block title %}Aufgaben{% endblock %}

{% block stylesheets %}
    <link href="{{ asset('styles/task/task.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}

<div class="container-fluid p-4">

    <!-- Header -->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold mb-1">Aufgaben</h1>

            <p class="text-muted">

                Behalte den Überblick über alle Aufgaben.

            </p>

        </div>

        <button class="btn btn-primary px-4">

            <i class="bi bi-plus-lg"></i>

            Neue Aufgabe

        </button>

    </div>

    <!-- Filter -->

    <div class="card border-0 shadow-sm mb-4">

        <div class="card-body">

            <div class="row g-3">

                <div class="col-lg-3">

                    <input

                        class="form-control"

                        placeholder="Aufgabe suchen...">

                </div>

                <div class="col-lg-2">

                    <select class="form-select">

                        <option>Status</option>

                        <option>To Do</option>

                        <option>In Progress</option>

                        <option>Review</option>

                        <option>Done</option>

                    </select>

                </div>

                <div class="col-lg-2">

                    <select class="form-select">

                        <option>Priorität</option>

                        <option>Hoch</option>

                        <option>Mittel</option>

                        <option>Niedrig</option>

                    </select>

                </div>

                <div class="col-lg-2">

                    <select class="form-select">

                        <option>Projekt</option>

                    </select>

                </div>

                <div class="col-lg-3">

                    <select class="form-select">

                        <option>Zugewiesen an</option>

                    </select>

                </div>

            </div>

        </div>

    </div>

    <!-- Table -->

    <div class="card border-0 shadow-sm">

        <div class="table-responsive">

            <table class="table align-middle mb-0">

                <thead>

                <tr>

                    <th></th>

                    <th>Aufgabe</th>

                    <th>Projekt</th>

                    <th>Zugewiesen</th>

                    <th>Status</th>

                    <th>Priorität</th>

                    <th>Deadline</th>

                    <th></th>

                </tr>

                </thead>

                <tbody>

                {% for task in tasks %}

                    <tr>

                        <td>

                            <input

                                type="checkbox"

                                class="form-check-input">

                        </td>

                        <td>

                            <div class="fw-semibold">

                                {{ task.title }}

                            </div>

                            <small class="text-muted">

                                {{ task.description }}

                            </small>

                        </td>

                        <td>

                            <span class="project-dot"></span>

                            {{ task.project.name }}

                        </td>

                        <td>

                            <div class="d-flex align-items-center gap-2">

                                <img

                                    src="https://i.pravatar.cc/40?img={{ loop.index }}"

                                    class="user-avatar">

                                {{ task.assignee }}

                            </div>

                        </td>

                        <td>

                            <span class="status-badge status-{{ task.status|lower|replace({' ':'-'}) }}">

                                {{ task.status }}

                            </span>

                        </td>

                        <td>

                            <span class="priority priority-{{ task.priority|lower }}">

                                {{ task.priority }}

                            </span>

                        </td>

                        <td>

                            {{ task.deadline|date }}

                        </td>

                        <td>

                            <button

                                class="btn btn-light btn-sm">

                                <i class="bi bi-three-dots"></i>

                            </button>

                        </td>

                    </tr>

                {% endfor %}

                </tbody>

            </table>

        </div>

    </div>

</div>

{% endblock %}