{% extends 'base.html.twig' %}

{% block title %}Aufgaben{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="{{ asset('styles/task/task.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}

<div class="container-fluid p-4">

    <!-- Header -->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold mb-1">Aufgaben</h1>

            <p class="text-muted">

                Behalte den Überblick über alle Aufgaben.

            </p>

        </div>

        <button class="btn btn-primary px-4">

            <i class="bi bi-plus-lg"></i>

            Neue Aufgabe

        </button>

    </div>

    <!-- Filter -->

    <div class="card border-0 shadow-sm mb-4">

        <div class="card-body">

            <div class="row g-3">

                <div class="col-lg-3">

                    <input

                        class="form-control"

                        placeholder="Aufgabe suchen...">

                </div>

                <div class="col-lg-2">

                    <select class="form-select">

                        <option>Status</option>

                        <option>To Do</option>

                        <option>In Progress</option>

                        <option>Review</option>

                        <option>Done</option>

                    </select>

                </div>

                <div class="col-lg-2">

                    <select class="form-select">

                        <option>Priorität</option>

                        <option>Hoch</option>

                        <option>Mittel</option>

                        <option>Niedrig</option>

                    </select>

                </div>

                <div class="col-lg-2">

                    <select class="form-select">

                        <option>Projekt</option>

                    </select>

                </div>

                <div class="col-lg-3">

                    <select class="form-select">

                        <option>Zugewiesen an</option>

                    </select>

                </div>

            </div>

        </div>

    </div>

    <!-- Table -->

    <div class="card border-0 shadow-sm">

        <div class="table-responsive">

            <table class="table align-middle mb-0">

                <thead>

                <tr>

                    <th></th>

                    <th>Aufgabe</th>

                    <th>Projekt</th>

                    <th>Zugewiesen</th>

                    <th>Status</th>

                    <th>Priorität</th>

                    <th>Deadline</th>

                    <th></th>

                </tr>

                </thead>

                <tbody>

                {% for task in tasks %}

                    <tr>

                        <td>

                            <input

                                type="checkbox"

                                class="form-check-input">

                        </td>

                        <td>

                            <div class="fw-semibold">

                                {{ task.title }}

                            </div>

                            <small class="text-muted">

                                {{ task.description }}

                            </small>

                        </td>

                        <td>

                            <span class="project-dot"></span>

                            {{ task.project.name }}

                        </td>

                        <td>

                            {% if task.assignee %}

                                <div class="d-flex align-items-center gap-2">

                                    {% if task.assignee.avatarUrl %}

                                        <img
                                            src="{{ task.assignee.avatarUrl }}"
                                            class="user-avatar"
                                            alt="{{ task.assignee.fullName }}">

                                    {% else %}

                                        <div class="user-avatar-placeholder">
                                            {{ task.assignee.initials }}
                                        </div>

                                    {% endif %}

                                    <span>
                                        {{ task.assignee.fullName }}
                                    </span>

                                </div>

                            {% else %}

                                <span class="text-muted">
                                    Nicht zugewiesen
                                </span>

                            {% endif %}

                        </td>

                        <td>

                            <span class="status-badge status-{{ task.status|lower|replace({' ':'-'}) }}">

                                {{ task.status }}

                            </span>

                        </td>

                        <td>

                            <span class="priority priority-{{ task.priority|lower }}">

                                {{ task.priority }}

                            </span>

                        </td>

                        <td>

                            {{ task.dueDate ? task.dueDate|date('d.m.Y') : '-' }}

                        </td>

                        <td class="text-end">

                            <div class="dropdown">

                                <button

                                    class="table-action-btn"

                                    type="button"

                                    data-bs-toggle="dropdown"

                                    data-bs-popper="none"

                                    aria-expanded="false">

                                    <i class="bi bi-three-dots"></i>

                                </button>

                                <ul class="dropdown-menu dropdown-menu-end task-dropdown task-dropdown-fixed">

                                    <li>

                                        <a class="dropdown-item" href="{{ path('task_show', {id: task.id}) }}">

                                            <i class="bi bi-eye"></i>

                                            Aufgabe öffnen

                                        </a>

                                    </li>

                                    <li>

                                        <a class="dropdown-item" href="#">

                                            <i class="bi bi-pencil"></i>

                                            Bearbeiten

                                        </a>

                                    </li>

                                    <li>

                                        <a class="dropdown-item" href="#">

                                            <i class="bi bi-check2-circle"></i>

                                            Als erledigt markieren

                                        </a>

                                    </li>

                                    <li><hr class="dropdown-divider"></li>

                                    <li>

                                        <a class="dropdown-item text-danger" href="#">

                                            <i class="bi bi-trash"></i>

                                            Löschen

                                        </a>

                                    </li>

                                </ul>

                            </div>

                        </td>
                    </tr>

                {% endfor %}

                </tbody>

            </table>

        </div>

    </div>

</div>

{% endblock %}