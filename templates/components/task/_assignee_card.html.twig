<div class="sidebar-card task-assignee-card">

    <div class="sidebar-card-header">

        <div>
            <h4>
                <i class="bi bi-person"></i>
                Zugewiesen an
            </h4>

            <p>
                Verantwortliche Person für diese Aufgabe.
            </p>
        </div>

    </div>

    {% if task.assignee %}

        <div class="assignee-profile">

            {% if task.assignee.avatarUrl %}

                <img
                    src="{{ task.assignee.avatarUrl }}"
                    alt="{{ task.assignee.fullName }}"
                    class="assignee-avatar">

            {% else %}

                <div class="assignee-placeholder">
                    {{ task.assignee.initials }}
                </div>

            {% endif %}

            <div class="assignee-info">

                <strong>
                    {{ task.assignee.fullName }}
                </strong>

                <small>
                    UI/UX Designer
                </small>

            </div>

            <button
                type="button"
                class="assignee-mail-btn"
                aria-label="E-Mail senden">

                <i class="bi bi-envelope"></i>

            </button>

        </div>

    {% else %}

        <div class="assignee-empty">

            <i class="bi bi-person-plus"></i>

            <div>
                <strong>Nicht zugewiesen</strong>

                <small>
                    Diese Aufgabe hat noch keine verantwortliche Person.
                </small>
            </div>

        </div>

    {% endif %}

    <button
        type="button"
        class="assignee-change-btn"
        data-bs-toggle="modal"
        data-bs-target="#taskAssigneeModal">

        <i class="bi bi-person-gear"></i>
        Assignee ändern

    </button>

</div>