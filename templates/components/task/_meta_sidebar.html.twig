<div class="sidebar-card task-details-card">

    <div class="sidebar-card-header">

        <div>
            <h4>
                <i class="bi bi-person-lines-fill"></i>
                Details
            </h4>

            <p>
                Wichtige Informationen zu dieser Aufgabe.
            </p>
        </div>

    </div>

    <div class="details-list">

        <div class="detail-row">

            <div class="detail-icon">
                <i class="bi bi-flag"></i>
            </div>

            <div class="detail-content">
                <span>Erstellt am</span>

                <strong>
                    {{ task.createdAt ? task.createdAt|date('d. F Y') : '-' }}
                </strong>
            </div>

        </div>

        <div class="detail-row is-editable">

            <div class="detail-icon">
                <i class="bi bi-calendar-event"></i>
            </div>

            <div class="detail-content">
                <span>Fälligkeitsdatum</span>

                <strong>
                    {{ task.dueDate ? task.dueDate|date('d. F Y') : 'Kein Datum' }}
                </strong>
            </div>

            <button
                type="button"
                class="detail-edit-btn"
                data-bs-toggle="modal"
                data-bs-target="#taskDueDateModal"
                aria-label="Fälligkeitsdatum bearbeiten">

                <i class="bi bi-pencil"></i>

            </button>

        </div>

        <div class="detail-row is-editable">

            <div class="detail-icon">
                <i class="bi bi-clock"></i>
            </div>

            <div class="detail-content">
                <span>Geschätzter Aufwand</span>

                <strong>
                    {# TODO: Reale "estimated time" werte verwenden nach implementation #}
                    8h
                </strong>
            </div>

            {# TODO: Implement taskEstimatedTimeModal #}
            <button
                type="button"
                class="detail-edit-btn"
                data-bs-toggle="modal"
                data-bs-target="#taskEstimatedTimeModal"
                aria-label="Geschätzter Aufwand bearbeiten">

                <i class="bi bi-pencil"></i>

            </button>

        </div>

        <div class="detail-row is-editable">

            <div class="detail-icon">
                <i class="bi bi-stopwatch"></i>
            </div>

            <div class="detail-content">
                <span>Verbrauchte Zeit</span>

                <strong>
                    {# TODO: Reale "time spent" werte verwenden nach implementation #}
                    3h 20m
                </strong>
            </div>

            {# TODO: Implement taskSpendTimeModal #}
            <button
                type="button"
                class="detail-edit-btn"
                data-bs-toggle="modal"
                data-bs-target="#taskSpentTimeModal"
                aria-label="Geschätzter Aufwand bearbeiten">

                <i class="bi bi-pencil"></i>

            </button>

        </div>

    </div>

    <div class="sidebar-progress-row">

        <div class="sidebar-progress-header">

            <span>Fortschritt</span>

            <strong>
                {{ task.subtaskProgress }}%
            </strong>

        </div>

        <div class="sidebar-progress">

            <div
                class="sidebar-progress-bar"
                style="width: {{ task.subtaskProgress }}%">
            </div>

        </div>

    </div>

</div>