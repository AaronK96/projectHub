<div {{ attributes }}>

    <div class="subtasks-header">

        <div>
            <h3>Unteraufgaben</h3>
            <p>Teile diese Aufgabe in kleinere, übersichtliche Schritte auf.</p>
        </div>

        <button class="btn-primary-action">
            <i class="bi bi-plus-lg"></i>
            Unteraufgabe hinzufügen
        </button>

    </div>

    <div class="subtasks-progress">

        <div class="d-flex justify-content-between mb-2">
            <span>Fortschritt</span>
            <strong>{{ this.progress }}%</strong>
        </div>

        <div class="progress">
            <div
                class="progress-bar"
                style="width: {{ this.progress }}%">
            </div>
        </div>

        <small>
            {{ this.completedCount }} von {{ this.totalCount }} Unteraufgaben erledigt
        </small>

    </div>

    <div class="subtask-card-list">

        {% for subtask in task.subtasks %}

            <div class="subtask-card {{ subtask.completed ? 'is-done' }}">

                <button
                    type="button"
                    class="subtask-check"
                    data-action="live#action"
                    data-live-action-param="toggleSubtask"
                    data-live-subtask-id-param="{{ subtask.id }}">

                    {% if subtask.completed %}
                        <i class="bi bi-check-circle-fill"></i>
                    {% else %}
                        <i class="bi bi-circle"></i>
                    {% endif %}

                </button>

                <div class="subtask-content">

                    <div class="subtask-title-row">

                        <h4>{{ subtask.title }}</h4>

                        {% if subtask.completed %}
                            <span class="subtask-status done">Erledigt</span>
                        {% else %}
                            <span class="subtask-status todo">Offen</span>
                        {% endif %}

                    </div>

                    {% if subtask.description %}
                        <p>{{ subtask.description }}</p>
                    {% endif %}

                    <div class="subtask-meta">

                        <span>
                            <i class="bi bi-list-ol"></i>
                            Position {{ subtask.position ?? loop.index }}
                        </span>

                    </div>

                </div>

            </div>

        {% else %}

            <div class="empty-state">
                Noch keine Unteraufgaben vorhanden.
            </div>

        {% endfor %}

    </div>

</div>