{% extends 'base.html.twig' %}

{% block body %}

    <!-- Topbar -->

    <div class="d-flex justify-content-between align-items-center py-4">

        <div>

            <h2 class="fw-bold">Übersicht</h2>

            <p class="text-muted mb-0">

                Willkommen zurück, Max 👋

            </p>

        </div>

        <div>

            <button class="btn btn-outline-secondary">

                <i class="bi bi-bell"></i>

            </button>

            <button class="btn btn-primary">

                Neues Projekt

            </button>

        </div>

    </div>

    <!-- Statistics -->

    <div class="row g-4 mb-4">

        <div class="col-md-3">
            <div class="stat-card stat-purple">
                <small>Projekte</small>
                <h2>{{ projects|length }}</h2>
                <span>Aktive Projekte</span>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card stat-blue">
                <small>Tasks</small>
                <h2>{{ taskCount['open'] }}</h2>
                <span>Offene Aufgaben</span>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card stat-green">
                <small>Teammitglieder</small>
                <h2>24</h2>
                <span>Online</span>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card stat-orange">
                <small>Erledigt</small>
                <h2>128</h2>
                <span>Diese Woche</span>
            </div>
        </div>

    </div>

    <!-- Widgets -->

    <div class="row g-3 mb-4">

        <div class="col-md-4">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-header bg-white">

                    Projekte

                </div>

                <div class="card-body">

                    {% for project in projects %}
                        <div class="mb-3">

                            <div class="d-flex justify-content-between">

                                <span>{{ project.name }}</span>

                                <span>{{ progress[project.id] }}%</span>

                            </div>

                            <div class="progress">

                                <div class="progress-bar" style="width:{{ progress[project.id] }}%"></div>

                            </div>

                        </div>
                    {% endfor %}

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-header bg-white">

                    Aufgabenübersicht

                </div>

                <div class="card-body">

                    <ul class="list-group list-group-flush">

                        <li class="list-group-item">

                            Offen: {{ taskCount['open'] }}

                        </li>

                        <li class="list-group-item">

                            In Arbeit: {{ taskCount['active'] }}

                        </li>

                        <li class="list-group-item">

                            Review: {{ taskCount['review'] }}

                        </li>

                        <li class="list-group-item">

                            Erledigt: {{ taskCount['done'] }}

                        </li>

                    </ul>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-header bg-white">

                    Aktivitäten

                </div>

                <div class="card-body">

                    <ul class="list-group list-group-flush">

                        <li class="list-group-item">

                            Lisa hat Task kommentiert

                        </li>

                        <li class="list-group-item">

                            Neue API Integration erstellt

                        </li>

                        <li class="list-group-item">

                            Sprint Planning morgen

                        </li>

                    </ul>

                </div>

            </div>

        </div>

    </div>

    <!-- Kanban -->

    <div class="row g-3">

        <div class="col-md-3">

            <div class="card shadow-sm border-0">

                <div class="card-header">

                    To Do

                </div>

                <div class="card-body">

                    <div class="card mb-2">

                        <div class="card-body">

                            Login Page erstellen

                        </div>

                    </div>

                    <div class="card">

                        <div class="card-body">

                            SEO Optimierung

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card shadow-sm border-0">

                <div class="card-header">

                    In Arbeit

                </div>

                <div class="card-body">

                    <div class="card">

                        <div class="card-body">

                            API Integration

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card shadow-sm border-0">

                <div class="card-header">

                    Review

                </div>

                <div class="card-body">

                    <div class="card">

                        <div class="card-body">

                            UI Review

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card shadow-sm border-0">

                <div class="card-header">

                    Erledigt

                </div>

                <div class="card-body">

                    <div class="card">

                        <div class="card-body">

                            Projekt Setup

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

{% endblock %}